rules_version = '2';

// Each user can read and write ONLY their own profile document (users/{uid}).
// Nobody can read or write anyone else's progress, and nobody can touch the
// database without being signed in. This is what actually keeps each person's
// progress private and safe.
service cloud.firestore {
  match /databases/{database}/documents {
    // Admin is granted by a server-set custom claim (admin:true), NOT by email.
    // The app uses email/password sign-in with no email verification, so an
    // email claim is just an unverified string a stranger could register —
    // matching on it would let anyone who types an admin's email become admin.
    // The claim is set only by scripts/setAdminClaims.ts via the Admin SDK and
    // cannot be forged by a client. Grant a new admin: add them to that script,
    // run it, have them re-login, then redeploy these rules.
    function isAdmin() {
      return request.auth != null && request.auth.token.admin == true;
    }

    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Entitlement + metered-usage fields are written ONLY by the trusted
    // payments backend via the Firebase Admin SDK (which bypasses these rules).
    // A client must never set or change them, or it could grant itself a paid
    // plan, extend its own expiry, mint free eval credits, or reset its AI
    // quota. The client strips these before every write (stripServerOwnedFields).
    // `promo` carries a teacher code's discount + commission rate. If a client
    // could write it, anyone could grant themselves a 100%-off code. It is set
    // ONLY by the promo backend (/api/promo/redeem) via the Admin SDK.
    function serverOwnedFields() {
      return ['billing', 'placementCredits', 'aiUsage', 'promo'];
    }
    function createOmitsServerFields() {
      return !request.resource.data.keys().hasAny(serverOwnedFields());
    }
    function updateKeepsServerFields() {
      return !request.resource.data.diff(resource.data).affectedKeys().hasAny(serverOwnedFields());
    }

    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if (isOwner(userId) && createOmitsServerFields()) || isAdmin();
      allow update: if (isOwner(userId) && updateKeepsServerFields()) || isAdmin();
      allow delete: if isOwner(userId);
    }

    match /payments/{paymentId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    match /subscriptions/{subscriptionId} {
      allow get, list, create, update, delete: if isAdmin();
    }

    // Teacher affiliate codes + commission ledger. Written ONLY by the promo
    // backend via the Admin SDK (which bypasses rules); the admin dashboard
    // reads them. No client read/write — discount/commission rates and earnings
    // stay private, and students cannot mint or alter codes.
    match /teacherCodes/{code} {
      allow get, list, create, update, delete: if isAdmin();
    }
    match /commissions/{commissionId} {
      allow get, list, update: if isAdmin();
    }

    // Per-day anonymous traffic counters (visits + signup funnel). Written ONLY
    // by the /api/track backend via the Admin SDK (which bypasses rules); the
    // admin dashboard reads them. No client read/write — visitors increment via
    // the server endpoint, never by touching Firestore directly.
    match /analytics/{day} {
      allow get, list: if isAdmin();
    }
  }
}
