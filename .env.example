# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# --- AI cost / abuse guards (optional; sensible defaults if unset) ----------
# AI_RATE_PER_MIN: max AI requests per IP per minute before HTTP 429.
AI_RATE_PER_MIN="30"
# AI_DAILY_BUDGET: total AI calls/day across all users; past it, checks fall
# back to the offline rule-based response (resets at UTC midnight).
AI_DAILY_BUDGET="500"
# AI_MAX_TEXT_CHARS: per text field sent to the model (longer is truncated).
AI_MAX_TEXT_CHARS="4000"
# AI_MAX_AUDIO_BYTES: max decoded speaking-audio size; larger is rejected (413).
AI_MAX_AUDIO_BYTES="6000000"

# --- Mongolia payments: QPay -------------------------------------------------
# QPAY_BASE_URL: Use sandbox while testing, then switch to https://merchant.qpay.mn
# after QPay approves production credentials.
QPAY_BASE_URL="https://merchant-sandbox.qpay.mn"
# QPAY_USERNAME/QPAY_PASSWORD: OAuth2 client_id/client_secret from QPay.
QPAY_USERNAME="MY_QPAY_CLIENT_ID"
QPAY_PASSWORD="MY_QPAY_CLIENT_SECRET"
# QPAY_INVOICE_CODE: Merchant invoice code assigned by QPay.
QPAY_INVOICE_CODE="MY_QPAY_INVOICE_CODE"
# QPAY_CALLBACK_URL: Optional override. If omitted, the backend uses APP_URL.
QPAY_CALLBACK_URL="https://MY_APP_URL/api/payments/qpay/webhook"

# --- Subscription plans (Free / Pro / Max) -----------------------------------
# Prices in Mongolian tugrik. Pro = all content + 5 AI teaser uses/month.
# Max = everything with unlimited AI. Annual ≈ 10× monthly (2 months free).
PLAN_PRO_AMOUNT_MNT="19900"
PLAN_PRO_YEAR_AMOUNT_MNT="199000"
PLAN_MAX_AMOUNT_MNT="39900"
PLAN_MAX_YEAR_AMOUNT_MNT="399000"
# Monthly AI teaser quotas for non-Max plans (Free / Pro).
AI_TEASER_FREE="2"
AI_TEASER_PRO="5"
# FOUNDER_EMAILS: comma-separated emails that always get full access for free.
# The founder address hanaa5qn@icloud.com is always included automatically.
FOUNDER_EMAILS="hanaa5qn@icloud.com"

# --- Server Firebase Admin for payment webhooks -----------------------------
# Required so the backend can verify Firebase ID tokens and write paid records.
# Prefer one JSON secret in production:
FIREBASE_SERVICE_ACCOUNT_JSON='{"project_id":"MY_FIREBASE_PROJECT_ID","client_email":"firebase-adminsdk@example.iam.gserviceaccount.com","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"}'
# Or use split values:
FIREBASE_PROJECT_ID="MY_FIREBASE_PROJECT_ID"
FIREBASE_CLIENT_EMAIL="firebase-adminsdk@example.iam.gserviceaccount.com"
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
